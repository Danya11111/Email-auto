# Copy to .env and adjust. Values are examples only.

# development | staging | production
APP_ENV=development

# SQLite database file (created by init-db)
DATABASE_PATH=./data/mail_assistant.sqlite3

# Writable data root (exports, optional attachments cache)
DATA_DIR=./data

# LM Studio OpenAI-compatible server
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen3-8b
LM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# Low-memory local inference defaults (MacBook Air M1 8GB friendly)
LLM_MAX_INPUT_CHARS=7000
LLM_MAX_OUTPUT_TOKENS=512
# Kept for future expansion; MVP forces sequential processing internally.
LLM_CONCURRENCY=1

# Batching (sequential loops; these are per-run caps, not parallel workers)
TRIAGE_BATCH_SIZE=10
TASK_EXTRACTION_BATCH_SIZE=10

# Digest window + cap of newest messages included in digest context
DIGEST_LOOKBACK_HOURS=24
DIGEST_MAX_MESSAGES=30

# Kanban auto-sync gate (still requires AUTO_CREATE_KANBAN_TASKS=true)
TASK_CONFIDENCE_THRESHOLD=0.75

# Review queue gate for triage + extracted tasks (human-in-the-loop)
REVIEW_CONFIDENCE_THRESHOLD=0.72

# When true, KanbanPort may create cards (still gated by TASK_CONFIDENCE_THRESHOLD policy)
AUTO_CREATE_KANBAN_TASKS=false

# How to shrink bodies before LLM calls: head | head_tail | middle_snip
MESSAGE_BODY_TRUNCATE_STRATEGY=head_tail

# Optional: used by run-daily when set (directory of .eml files)
MAIL_EML_DIR=./data/inbox_eml

# Optional: used by run-daily when set (path to a single .mbox file)
MAIL_MBOX_PATH=
