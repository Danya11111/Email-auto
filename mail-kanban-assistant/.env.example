# Copy to .env and adjust. Values are examples only.

# development | staging | production
APP_ENV=development

# SQLite database file (created by init-db)
DATABASE_PATH=./data/mail_assistant.sqlite3

# Writable data root (exports, optional attachments cache)
DATA_DIR=./data

# LM Studio OpenAI-compatible server
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen3-8b
LM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# Low-memory local inference defaults (MacBook Air M1 8GB friendly)
LLM_MAX_INPUT_CHARS=7000
LLM_MAX_OUTPUT_TOKENS=512
# Kept for future expansion; MVP forces sequential processing internally.
LLM_CONCURRENCY=1

# Batching (sequential loops; these are per-run caps, not parallel workers)
TRIAGE_BATCH_SIZE=10
TASK_EXTRACTION_BATCH_SIZE=10

# Digest window + cap of newest messages included in digest context
DIGEST_LOOKBACK_HOURS=24
DIGEST_MAX_MESSAGES=30

# Thread-aware Action Center (deterministic; no extra LLM by default)
ACTION_CENTER_LOOKBACK_HOURS=72
ACTION_CENTER_MAX_ITEMS=40
ACTION_CENTER_MAX_MESSAGES=300
ACTION_CENTER_INCLUDE_INFORMATIONAL=false
REPLY_OVERDUE_HOURS=48
REPLY_RECOMMENDED_HOURS=24
THREAD_GROUPING_TIME_WINDOW_HOURS=96
ACTION_CENTER_USE_LLM_EXECUTIVE_SUMMARY=false
ACTION_CENTER_EXECUTIVE_SUMMARY_MAX_ITEMS=4
ACTION_CENTER_REQUIRE_REVIEW_FOR_AMBIGUOUS_REPLY=true

# Minimum model confidence for task automation policies (extraction / optional extract-time Kanban hints).
TASK_CONFIDENCE_THRESHOLD=0.75

# Review queue gate for triage + extracted tasks (human-in-the-loop)
REVIEW_CONFIDENCE_THRESHOLD=0.72

# When true, KanbanPort may create cards during extraction (still gated by TASK_CONFIDENCE_THRESHOLD policy).
# This is separate from the approved-task sync pipeline (`kanban-sync`).
AUTO_CREATE_KANBAN_TASKS=false

# --- Kanban sync (approved tasks → provider) ---
# Provider: local_file | trello | yougile | stub (stub counts as skipped / no external writes)
KANBAN_PROVIDER=local_file
# When true, run-daily and review-approve may trigger sync (see docs); off by default for safety.
KANBAN_AUTO_SYNC=false
# Root for local_file cards + board.md export
KANBAN_ROOT_DIR=./data/kanban/local_board
# Default list/column semantics for mapping (todo | in_progress | done | blocked)
KANBAN_DEFAULT_STATUS=todo
KANBAN_SYNC_BATCH_SIZE=50
KANBAN_RETRY_LIMIT=5
KANBAN_INCLUDE_REVIEW_METADATA=true
KANBAN_INCLUDE_MESSAGE_METADATA=true
KANBAN_MAX_TITLE_CHARS=120
KANBAN_MAX_DESC_CHARS=4000
KANBAN_HTTP_TIMEOUT_SECONDS=25

# Trello (only when KANBAN_PROVIDER=trello)
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LIST_ID_TODO=
TRELLO_LIST_ID_DONE=
TRELLO_LIST_ID_BLOCKED=

# YouGile (only when KANBAN_PROVIDER=yougile). Use API key from YouGile UI — never store account password here.
# Base host or full API root; /api-v2 is appended when missing.
YOUGILE_BASE_URL=https://ru.yougile.com
YOUGILE_API_KEY=
# Optional documentation / future use (not required for Bearer requests)
YOUGILE_COMPANY_ID=
YOUGILE_BOARD_ID=
YOUGILE_COLUMN_ID_TODO=
YOUGILE_COLUMN_ID_DONE=
YOUGILE_COLUMN_ID_BLOCKED=
YOUGILE_REQUEST_TIMEOUT_SECONDS=25
# Stay under YouGile company limit of 50 requests/minute
YOUGILE_REQUESTS_PER_MINUTE=40
# When false (default), fingerprint changes after a successful sync skip remote writes (no silent duplicates).
YOUGILE_ENABLE_UPDATE_EXISTING=false
YOUGILE_INCLUDE_INTERNAL_IDS=true
YOUGILE_ATTACH_SOURCE_METADATA=true
YOUGILE_MAX_DESCRIPTION_CHARS=12000
# Reserved for future sticker mapping (priority is always included in description text today)
YOUGILE_PRIORITY_STICKER_NAME=
YOUGILE_PRIORITY_STATE_LOW=
YOUGILE_PRIORITY_STATE_MEDIUM=
YOUGILE_PRIORITY_STATE_HIGH=
YOUGILE_PRIORITY_STATE_CRITICAL=
# Scaffold only: future YouGile assignee user id (not sent on API in MVP)
YOUGILE_DEFAULT_ASSIGNEE_EXTERNAL_ID=

# How to shrink bodies before LLM calls: head | head_tail | middle_snip
MESSAGE_BODY_TRUNCATE_STRATEGY=head_tail

# Optional: used by run-daily when set (directory of .eml files)
MAIL_EML_DIR=./data/inbox_eml

# Optional: used by run-daily when set (path to a single .mbox file)
MAIL_MBOX_PATH=

# Apple Mail JSON snapshot maildrop (incoming/processed/failed/exported)
MAILDROP_ROOT=./data/maildrop

# LaunchAgent label used by print-launchd / install-launchd
LAUNCHD_LABEL=com.local.mailassistant
